  "keyFeatures": [
    "24/7 AI chatbot that handles customer inquiries automatically",
    "Lead qualification engine that filters serious buyers from casual browsers",
    "Real-time analytics dashboard with conversation, sales, and traffic metrics",
    "Vehicle inventory catalog with search and filter capabilities",
    "Automated appointment scheduling synced with dealer calendars",
    "WhatsApp and email integration for lead follow-up",
