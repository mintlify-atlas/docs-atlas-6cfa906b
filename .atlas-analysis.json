  "publicApiSurface": [
    "POST /api/auth/register — Register a new dealer account",
    "POST /api/auth/login — Authenticate and start a session",
    "POST /api/auth/logout — End the current session",
    "GET /api/user — Get current authenticated user",
    "GET /api/cars — List vehicles in inventory",
    "POST /api/cars — Add a vehicle to inventory",
    "GET /api/cars/:id — Get vehicle details",
    "GET /api/dealers — List certified dealers",
    "GET /api/dealers/:id — Get dealer details",
    "createApp() — Express application factory (server/index.ts)",
    "registerRoutes(httpServer, app) — Register API routes (server/routes.ts)",
    "IStorage.getUser(id) — Retrieve user by ID (server/storage.ts)",
    "IStorage.getUserByUsername(username) — Retrieve user by username (server/storage.ts)",
    "IStorage.createUser(user) — Create a new user (server/storage.ts)"
  ]
